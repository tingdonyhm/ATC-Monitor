{
  "functions": {
    "api/opensky.cjs": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/opensky",
      "destination": "/api/opensky.cjs"
    },
    {
      "source": "/aviationstack/:path*",
      "destination": "http://api.aviationstack.com/:path*"
    }
  ]
}
